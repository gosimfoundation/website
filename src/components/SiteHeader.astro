---
import { getLangFromUrl, useTranslations, localizedPath } from '../i18n/utils';
import LanguagePicker from './LanguagePicker.astro';

interface Props {
  /** Full-bleed hero pages start transparent; content pages start solid. */
  transparent?: boolean;
}
const { transparent = false } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const home = localizedPath('/', lang);

// Nav mirrors the homepage sections (anchor links so they work from any page).
const links = [
  { href: `${home}#about`, label: t('nav.about') },
  { href: `${home}#pillars`, label: t('nav.pillars') },
  { href: `${home}#events`, label: t('nav.events') },
  { href: `${home}#spotlights`, label: t('nav.spotlights') },
];
---

<header class={`site-header fixed inset-x-0 top-0 z-20 ${transparent ? '' : 'is-solid'}`}>
  <div class="flex min-h-[78px] items-center justify-between gap-6 px-5 py-4 sm:px-8 lg:px-[72px]">
    <a href={home} class="shrink-0" aria-label="GOSIM home">
      <img src="/logo.svg" alt="GOSIM" width="112" height="32" class="w-28" />
    </a>

    <nav class="flex items-center gap-4 text-sm sm:gap-6 lg:gap-8">
      {links.map((l) => (
        <a href={l.href} class="hidden transition-colors hover:text-teal sm:inline">{l.label}</a>
      ))}
      <LanguagePicker />
      <a
        href={`${home}#upcoming`}
        class="tech-label inline-flex min-h-[42px] items-center rounded-full bg-lime px-5 py-3 text-ink transition-transform hover:-translate-y-0.5"
      >
        {t('nav.upcoming')}
      </a>
    </nav>
  </div>
</header>
