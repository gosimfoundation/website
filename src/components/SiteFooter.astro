---

<footer class="mt-12 border-t border-line bg-mist/40">
  <div class="px-5 py-16 sm:px-8 lg:px-[72px]">
    <div class="flex flex-col gap-12 md:flex-row md:items-start md:justify-between">
      <!-- Brand + social -->
      <div class="max-w-xs">
        <img src="/logo.svg" alt="GOSIM" width="112" height="32" class="w-28" />
        <p class="mt-4 text-sm text-muted">{t('footer.tagline')}</p>
        <div class="mt-6 flex gap-3">
          {
            socials.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={s.label}
                class="flex h-10 w-10 items-center justify-center rounded-full border border-line text-ink transition-colors hover:border-ink hover:bg-ink hover:text-paper"
              >
                <svg viewBox="0 0 24 24" fill="currentColor" class="h-[18px] w-[18px]" aria-hidden="true">
                  <path d={s.path} />
                </svg>
              </a>
            ))
          }
        </div>
      </div>

      <!-- Section links — two columns -->
      <div class="flex gap-12 sm:gap-16 md:gap-20">
        {
          footerCols.map((col) => (
            <nav class="flex flex-col gap-2 text-sm">
              {col.map((l) => (
                <a href={l.href} class="text-muted transition-colors hover:text-teal">
                  {l.label}
                </a>
              ))}
            </nav>
          ))
        }
      </div>
    </div>

    <div class="mt-12 flex flex-col gap-2 border-t border-line pt-6 text-xs text-muted sm:flex-row sm:items-center sm:justify-between">
      <span>© {year} GOSIM · Global Open-Source Innovation Meetup</span>
      <a href="/privacy" class="transition-colors hover:text-teal">{t('nav.privacy')}</a>
    </div>
  </div>
</footer>
