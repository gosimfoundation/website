---
import { render, type CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}
const { post } = Astro.props;
const { Content } = await render(post);
const dateLabel = new Intl.DateTimeFormat(post.data.lang === 'zh' ? 'zh-CN' : 'en-US', {
  dateStyle: 'long',
}).format(post.data.date);
---

<article class="mx-auto max-w-2xl px-5 pt-36 pb-24 sm:px-8">
  <p class="text-xs font-semibold tracking-wide text-teal uppercase">{post.data.author}</p>
  <h1 class="mt-3 text-4xl leading-tight font-bold sm:text-5xl">{post.data.title}</h1>
  <p class="mt-4 text-muted">{dateLabel}</p>
  <div class="article-body mt-10">
    <Content />
  </div>
</article>

<style>
  .article-body :global(p) {
    margin: 1.25rem 0;
    line-height: 1.75;
    color: var(--color-ink);
  }
  .article-body :global(h2) {
    margin: 2.5rem 0 1rem;
    font-size: 1.75rem;
    font-weight: 600;
  }
  .article-body :global(h3) {
    margin: 2rem 0 0.75rem;
    font-size: 1.35rem;
    font-weight: 600;
  }
  .article-body :global(a) {
    color: var(--color-teal);
    text-decoration: underline;
  }
  .article-body :global(ul),
  .article-body :global(ol) {
    margin: 1.25rem 0;
    padding-left: 1.5rem;
    line-height: 1.75;
  }
  .article-body :global(li) {
    margin: 0.4rem 0;
  }
  .article-body :global(blockquote) {
    margin: 1.5rem 0;
    border-left: 3px solid var(--color-teal);
    padding-left: 1rem;
    color: var(--color-muted);
    font-style: italic;
  }
  .article-body :global(img) {
    border-radius: 0.75rem;
    margin: 1.5rem 0;
  }
</style>
