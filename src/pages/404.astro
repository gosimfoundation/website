---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found — GOSIM">
  <section class="mx-auto flex min-h-[70svh] max-w-2xl flex-col justify-center px-5 sm:px-8">
    <p class="text-xs font-semibold tracking-wide text-teal uppercase">404</p>
    <h1 class="mt-2 text-5xl font-bold sm:text-6xl">This page went off the map.</h1>
    <p class="mt-4 text-lg text-muted">The page you’re looking for doesn’t exist yet.</p>
    <a href="/" class="mt-8 inline-flex w-fit items-center rounded-full bg-ink px-6 py-3 font-semibold text-paper">
      Back home
    </a>
  </section>
</BaseLayout>
